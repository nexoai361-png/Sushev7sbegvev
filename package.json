{
  "name": "reversx-ide",
  "private": true,
  "version": "1.0.0",
  "description": "ReversX Professional IDE for Mobile and Web",
  "author": "ReversX Team",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "start": "node dist/server.cjs",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "sonar": "sonar-scanner",
    "assets:generate": "capacitor-assets generate --android --iconBackgroundColor '#1E1E1E'",
    "cap:sync": "npx cap sync",
    "cap:build": "npm run build && npm run assets:generate && npx cap sync android"
  },
  "dependencies": {
    "@capacitor-community/speech-recognition": "^7.0.1",
    "@capacitor/android": "^8.4.2",
